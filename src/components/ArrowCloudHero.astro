<section class="arrow-cloud">
    <div class="arrow-cloud__canvas" data-arrow-cloud></div>
</section>
<script>
    import { createArrowCloudScene } from "../lib/arrow-cloud/src/createArrowCloudScene";
    import { animationSettings, arrowPaths, cameraTrack } from "../arrowData.js";

    const mountElement = document.querySelector('[data-arrow-cloud]');
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce').matches;

    if (mountElement && !prefersReducedMotion) {
        const arrowCloudScene = createArrowCloudScene(mountElement, {
            animationSettings,
            arrowPaths,
            cameraTrack
        });

        document.addEventListener('astro:before-swap', () => {
            arrowCloudScene.destroy();
        }, { once: true});
    }
</script>
<style>
    .arrow-cloud {
        position: relative;
        min-height: 100vh;
        overflow: hidden;
    }

    .arrow-cloud__canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }

    .arrow-cloud__canvas canvas {
        display: block;
        width: 100%;
        height: 100%;
    }
</style>